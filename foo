From cf61e0bfa5d7238c35d16abc974b41dd03ef2ecf Mon Sep 17 00:00:00 2001
From: keanehatescoding <keane@archlinux>
Date: Fri, 17 Jul 2026 20:57:49 +0000
Subject: [PATCH] fix: don't swallow CancellationException in
 callable/worker/UI catch blocks

- FunctionsQuizDataSource.finalizeQuizAttempt, FunctionsModuleDataSource
  .completeModule: rethrow CancellationException before falling through
  to the generic Exception catch, matching the resultOf/AuthRepositoryImpl
  convention used elsewhere
- SyncQuizResultsWorker: rethrow CancellationException out of the
  best-effort finalize block instead of reporting a cancelled worker as
  a Crashlytics error + Result.success()
- CertificateScreen: wrap the "Share certificate" button body in
  try/catch (it previously had none, so a thrown exception left
  isGenerating stuck true forever); also rethrow CancellationException
  in saveToDownloads
---
 .../firebase/FunctionsModuleDataSource.kt     |  3 ++
 .../core/firebase/FunctionsQuizDataSource.kt  |  3 ++
 .../core/sync/SyncQuizResultsWorker.kt        |  6 ++++
 .../feature/profile/CertificateScreen.kt      | 30 ++++++++++++-------
 4 files changed, 32 insertions(+), 10 deletions(-)

diff --git a/app/src/main/java/com/example/cybershield/core/firebase/FunctionsModuleDataSource.kt b/app/src/main/java/com/example/cybershield/core/firebase/FunctionsModuleDataSource.kt
index b530d52..54804c8 100644
--- a/app/src/main/java/com/example/cybershield/core/firebase/FunctionsModuleDataSource.kt
+++ b/app/src/main/java/com/example/cybershield/core/firebase/FunctionsModuleDataSource.kt
@@ -5,6 +5,7 @@ import com.example.cybershield.core.domain.util.Result
 import com.google.firebase.functions.FirebaseFunctions
 import com.google.firebase.functions.FirebaseFunctionsException
 import com.google.firebase.functions.HttpsCallableResult
+import kotlinx.coroutines.CancellationException
 import kotlinx.coroutines.tasks.await
 import javax.inject.Inject
 import javax.inject.Singleton
@@ -36,6 +37,8 @@ class FunctionsModuleDataSource
                         xpEarned = data.optInt("xpEarned"),
                     ),
                 )
+            } catch (e: CancellationException) {
+                throw e
             } catch (e: FirebaseFunctionsException) {
                 Result.Error(Exception(e.message ?: "completeModule failed", e))
             } catch (e: Exception) {
diff --git a/app/src/main/java/com/example/cybershield/core/firebase/FunctionsQuizDataSource.kt b/app/src/main/java/com/example/cybershield/core/firebase/FunctionsQuizDataSource.kt
index 975a279..70b2d47 100644
--- a/app/src/main/java/com/example/cybershield/core/firebase/FunctionsQuizDataSource.kt
+++ b/app/src/main/java/com/example/cybershield/core/firebase/FunctionsQuizDataSource.kt
@@ -6,6 +6,7 @@ import com.example.cybershield.core.domain.util.Result
 import com.google.firebase.functions.FirebaseFunctions
 import com.google.firebase.functions.FirebaseFunctionsException
 import com.google.firebase.functions.HttpsCallableResult
+import kotlinx.coroutines.CancellationException
 import kotlinx.coroutines.tasks.await
 import javax.inject.Inject
 import javax.inject.Singleton
@@ -150,6 +151,8 @@ class FunctionsQuizDataSource
                         alreadyFinalized = data.optBoolean("alreadyFinalized"),
                     ),
                 )
+            } catch (e: CancellationException) {
+                throw e
             } catch (e: FirebaseFunctionsException) {
                 Result.Error(Exception(e.message ?: "finalize failed", e))
             } catch (e: Exception) {
diff --git a/app/src/main/java/com/example/cybershield/core/sync/SyncQuizResultsWorker.kt b/app/src/main/java/com/example/cybershield/core/sync/SyncQuizResultsWorker.kt
index d539ae1..ae51ed3 100644
--- a/app/src/main/java/com/example/cybershield/core/sync/SyncQuizResultsWorker.kt
+++ b/app/src/main/java/com/example/cybershield/core/sync/SyncQuizResultsWorker.kt
@@ -17,6 +17,7 @@ import com.example.cybershield.core.domain.util.CrashReporter
 import dagger.assisted.Assisted
 import dagger.assisted.AssistedInject
 import java.util.concurrent.TimeUnit
+import kotlinx.coroutines.CancellationException
 import com.example.cybershield.core.domain.util.Result as DomainResult
 
 @HiltWorker
@@ -47,6 +48,11 @@ constructor(
                 // isn't finalized yet.
                 try {
                     finalizeQuizAttempts()
+                } catch (e: CancellationException) {
+                    // Don't swallow cancellation — a WorkManager-cancelled
+                    // worker (constraints no longer met, app backgrounded,
+                    // etc.) must not be reported as a crash or as success.
+                    throw e
                 } catch (e: Exception) {
                     // Swallow — see comment above. The answers themselves are
                     // safely synced regardless of whether finalization ran.
diff --git a/app/src/main/java/com/example/cybershield/feature/profile/CertificateScreen.kt b/app/src/main/java/com/example/cybershield/feature/profile/CertificateScreen.kt
index 329747f..6cb64a9 100644
--- a/app/src/main/java/com/example/cybershield/feature/profile/CertificateScreen.kt
+++ b/app/src/main/java/com/example/cybershield/feature/profile/CertificateScreen.kt
@@ -50,6 +50,7 @@ import androidx.compose.ui.unit.sp
 import androidx.hilt.lifecycle.viewmodel.compose.hiltViewModel
 import androidx.lifecycle.compose.collectAsStateWithLifecycle
 import com.example.cybershield.core.data.CertificateGenerator
+import kotlinx.coroutines.CancellationException
 import kotlinx.coroutines.launch
 
 @OptIn(ExperimentalMaterial3Api::class)
@@ -107,6 +108,8 @@ fun CertificateScreen(
                 // Keep isGenerating = true until the permission result comes back.
                 pendingSave = { saveToDownloads(userName, quizTitle, score, date, id) }
                 permissionLauncher.launch(Manifest.permission.WRITE_EXTERNAL_STORAGE)
+            } catch (e: CancellationException) {
+                throw e
             } catch (e: Exception) {
                 isGenerating = false
                 snackbarHostState.showSnackbar("Couldn't save certificate: ${e.message}")
@@ -157,16 +160,23 @@ fun CertificateScreen(
                     onClick = {
                         scope.launch {
                             isGenerating = true
-                            val file =
-                                generator.generate(
-                                    userName = user.displayName,
-                                    quizTitle = cert.quizTitle,
-                                    score = cert.score,
-                                    date = cert.datePassed,
-                                    certId = cert.id,
-                                )
-                            isGenerating = false
-                            generator.share(context, file)
+                            try {
+                                val file =
+                                    generator.generate(
+                                        userName = user.displayName,
+                                        quizTitle = cert.quizTitle,
+                                        score = cert.score,
+                                        date = cert.datePassed,
+                                        certId = cert.id,
+                                    )
+                                isGenerating = false
+                                generator.share(context, file)
+                            } catch (e: CancellationException) {
+                                throw e
+                            } catch (e: Exception) {
+                                isGenerating = false
+                                snackbarHostState.showSnackbar("Couldn't share certificate: ${e.message}")
+                            }
                         }
                     },
                     enabled = !isGenerating,
