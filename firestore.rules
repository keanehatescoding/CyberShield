rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ── modules — readable by any signed-in user, admin-write only ────
    match /modules/{moduleId} {
      allow read: if request.auth != null;
      allow write: if false;
      // edit only via Firebase Console
    }

    // ── quizzes + questions — same pattern ─────────────────────────────
    // NOTE: after running functions/scripts/migrateAnswerKeys.ts, question
    // docs no longer contain correctIndex/explanation — those live only in
    // /answerKeys, which is unreadable from the client. Read access here is
    // still safe because there's nothing left in these docs to leak.
    match /quizzes/{quizId} {
      allow read: if request.auth != null;
      allow write: if false;

      // edit only via Firebase Console

      match /questions/{questionId} {
        allow read: if request.auth != null;
        allow write: if false;
      }
    }

    // ── answer keys — Cloud Functions only ─────────────────────────────
    // Holds correctIndex/explanation per question. The Admin SDK (used by
    // validateAnswer / validateAnswersBatch) bypasses these rules entirely,
    // so this collection is functionally invisible to every client build.
    match /answerKeys/{answerKeyId} {
      allow read, write: if false;
    }

    // ── users — only the owner can read/write their own document ──────
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      // badges (e.g. "CyberDefender") are issued server-side by the
      // finalizeQuizAttempt callable — the client must not write them.
      //
      // xp is likewise server-only now: it used to be incremented by a
      // direct client write (UserRepositoryImpl.addXp), which meant a
      // malicious authenticated client could set their own xp to anything
      // — no server logic ever checked the increment amount. XP is now
      // computed and applied only by finalizeQuizAttemptFn / completeModuleFn.
      //
      // completedModules is also server-only now: completeModuleFn sets it
      // atomically alongside the xp award it's tied to, so a client can no
      // longer "complete" a module (and imply an xp award) without going
      // through that callable.
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && !('badges' in request.resource.data)
                   && !('xp' in request.resource.data)
                   && !('completedModules' in request.resource.data);

      // Grading is server-side only now: the client calls validateAnswer /
      // validateAnswersBatch, and those Cloud Functions write here with the
      // Admin SDK. A direct client write (with a self-reported isCorrect)
      // is no longer possible — this closes the original vulnerability.
      match /quizResults/{resultId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }

      // Idempotency marker written by finalizeQuizAttemptFn so a retried
      // call never double-awards XP or double-issues a cert/badge.
      match /quizAttempts/{resultId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }

      match /progress/{moduleId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Certificates are issued server-side only, by finalizeQuizAttemptFn
      // (Admin SDK) once a quiz attempt passes — see grading.ts. A client
      // write rule here (even scoped to request.auth.uid == userId) would
      // let anyone with the app's bundled API key forge a certificate doc
      // under their own uid, which CertificateScreen would then happily
      // read and render. GenerateCertificateUseCase / saveCertificate is
      // dead client-side code and is not a legitimate writer of this
      // collection.
      match /certificates/{certId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }
    }

    // ── leaderboard — public-safe mirror, top-level collection ─────────
    // Mirrors ONLY displayName/xp/badges out of users/{uid}. This is a
    // sibling of /users/{userId}, NOT nested under it: the app queries
    // firestore.collection("leaderboard") at the top level, so the rule
    // has to live at the top level too, or the query is denied.
    //
    // Client-write is now fully disabled. Previously any signed-in user
    // could `set` their own leaderboard/{uid}.xp directly (same uid-match
    // pattern as /users/{userId}), which let them top the public
    // leaderboard with an arbitrary xp value — the doc's own write rule
    // never validated it against a real xp award. The doc is now created
    // by the onUserProfileCreated trigger at registration and updated only
    // by finalizeQuizAttemptFn / completeModuleFn via the Admin SDK, which
    // bypasses these rules entirely. Any signed-in user can still read the
    // whole collection, since it deliberately contains nothing sensitive.
    match /leaderboard/{userId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}