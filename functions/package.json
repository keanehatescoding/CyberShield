{
  "name": "cybershield-functions",
  "version": "1.0.0",
  "private": true,
  "description": "Server-side answer validation for CyberShield quizzes.",
  "engines": {
    "node": "24"
  },
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "lint": "eslint src",
    "test": "vitest run",
    "serve": "npm run build && firebase emulators:start --only functions,firestore",
    "shell": "npm run build && firebase functions:shell",
    "deploy": "npm run build && firebase deploy --only functions",
    "migrate:answerKeys": "npm run build && node lib/scripts/migrateAnswerKeys.js"
  },
  "dependencies": {
    "firebase-admin": "^14.2.0",
    "firebase-functions": "^7.3.0"
  },
  "devDependencies": {
    "typescript": "^7.0.2",
    "eslint": "^10.7.0",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  }
}
