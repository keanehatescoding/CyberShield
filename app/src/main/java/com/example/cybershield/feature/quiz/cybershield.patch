diff --git a/firestore.rules b/firestore.rules
new file mode 100644
index 0000000..9afa141
--- /dev/null
+++ b/firestore.rules
@@ -0,0 +1,69 @@
+rules_version = '2';
+service cloud.firestore {
+  match /databases/{database}/documents {
+
+    // ── modules — readable by any signed-in user, admin-write only ────
+    match /modules/{moduleId} {
+      allow read: if request.auth != null;
+      allow write: if false; // edit only via Firebase Console
+    }
+
+    // ── quizzes + questions — same pattern ─────────────────────────────
+    // NOTE: after running functions/scripts/migrateAnswerKeys.ts, question
+    // docs no longer contain correctIndex/explanation — those live only in
+    // /answerKeys, which is unreadable from the client. Read access here is
+    // still safe because there's nothing left in these docs to leak.
+    match /quizzes/{quizId} {
+      allow read: if request.auth != null;
+      allow write: if false; // edit only via Firebase Console
+
+      match /questions/{questionId} {
+        allow read: if request.auth != null;
+        allow write: if false;
+      }
+    }
+
+    // ── answer keys — Cloud Functions only ─────────────────────────────
+    // Holds correctIndex/explanation per question. The Admin SDK (used by
+    // validateAnswer / validateAnswersBatch) bypasses these rules entirely,
+    // so this collection is functionally invisible to every client build.
+    match /answerKeys/{answerKeyId} {
+      allow read, write: if false;
+    }
+
+    // ── users — only the owner can read/write their own document ──────
+    match /users/{userId} {
+      allow read, write: if request.auth != null && request.auth.uid == userId;
+
+      // Grading is server-side only now: the client calls validateAnswer /
+      // validateAnswersBatch, and those Cloud Functions write here with the
+      // Admin SDK. A direct client write (with a self-reported isCorrect)
+      // is no longer possible — this closes the original vulnerability.
+      match /quizResults/{resultId} {
+        allow read: if request.auth != null && request.auth.uid == userId;
+        allow write: if false;
+      }
+
+      match /progress/{moduleId} {
+        allow read, write: if request.auth != null && request.auth.uid == userId;
+      }
+
+      match /certificates/{certId} {
+        allow read, write: if request.auth != null && request.auth.uid == userId;
+      }
+    }
+
+    // ── leaderboard query — users collection ordered by xp ─────────────
+    // Already covered by the /users/{userId} rule above, BUT the
+    // leaderboard query reads OTHER users' documents, not just your own.
+    // The rule above would BLOCK this — see note below.
+    //
+    // If/when the leaderboard read is reinstated for other users' docs,
+    // do NOT loosen this to `allow read: if request.auth != null` on the
+    // whole /users/{userId} doc — that would also expose email, auth
+    // metadata, etc. Instead, project a public subset (displayName, xp,
+    // badges) into a separate `leaderboardEntries/{userId}` doc, written
+    // only by a Cloud Function trigger on XP changes, and make that
+    // collection readable by any signed-in user.
+  }
+}
